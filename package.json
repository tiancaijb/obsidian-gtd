{
	"name": "obsidian-gtd",
	"version": "0.2.1",
	"description": "Org-mode style GTD workflow for Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -p tsconfig.build.json -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"dev:vault": "node esbuild.config.mjs --vault \"/mnt/c/Users/wangy/Documents/Obsidian Vault\""
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/state": "^6.5.0",
		"@codemirror/view": "^6.38.6",
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"@vitest/coverage-v8": "^4.1.10",
		"@vitest/eslint-plugin": "^1.1.0",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"tsx": "^4.22.4",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.10"
	}
}
